# LLM API Configuration (阿里百炼)
DASHSCOPE_API_KEY=sk-your-api-key-here
LLM_MODEL=qwen3.6-flash
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding
EMBEDDING_MODEL=text-embedding-v3

# RAG
CHUNK_SIZE=600
CHUNK_OVERLAP=80
